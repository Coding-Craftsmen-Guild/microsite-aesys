    <Description><![CDATA[Page block: an Intro Text (eyebrow/title/text/button) with an overlay image behind it on one side, and a list of numbered solution cards (I, II, III, IV - alternating navy/green) on the other, in a 50/50 row. Optional section background via the Section mixin.]]></Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Nothing</Variations>
    <IsElement>true</IsElement>
    <HistoryCleanup>
