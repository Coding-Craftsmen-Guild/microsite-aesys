<?xml version="1.0" encoding="utf-8"?>
<ContentType Key="c0a7f3e1-2b4d-4f6a-8c1e-9d3b5a7e1f20" Alias="contactForm" Level="3">
  <Info>
    <Name>Contact Form</Name>
    <Icon>icon-message color-green</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description><![CDATA[Page block: an Intro Text (eyebrow/title/text/button) on the left and a contact form on the right, in a 50/50 row. The form fields (name, company, email, phone, message) are fixed; the editor sets the form heading/subtitle and the recipient address(es) submissions are emailed to. Optional section background via the Section mixin.]]></Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Nothing</Variations>
    <IsElement>true</IsElement>
    <HistoryCleanup>
      <PreventCleanup>False</PreventCleanup>
      <KeepAllVersionsNewerThanDays></KeepAllVersionsNewerThanDays>
      <KeepLatestVersionPerDayForDays></KeepLatestVersionPerDayForDays>
    </HistoryCleanup>
    <Folder>Shared</Folder>
    <Compositions>
      <Composition Key="76fed7ca-df43-4720-a52e-8659c9549fb1">introText</Composition>
      <Composition Key="02956852-8784-4059-b38f-a21bb7373a44">section</Composition>
    </Compositions>
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
  <GenericProperties>
    <GenericProperty>
      <Key>b1d8e4f2-3c5e-4a7b-9d2f-0e4c6b8a2f31</Key>
      <Name>Form Title</Name>
