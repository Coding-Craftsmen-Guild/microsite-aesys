<ContentType Key="a7d95184-b6b2-41a0-a854-72d08f9a10cf" Alias="map" Level="2">
  <Info>
    <Name>Map</Name>
    <Icon>icon-map color-green</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description><![CDATA[Reusable block: an Intro Text (eyebrow/title/text/button) beside an embedded Google Map, in a 50/50 row. Full-width text when no map. Optional section background via the Section mixin.]]></Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Nothing</Variations>
    <IsElement>true</IsElement>
    <HistoryCleanup>
      <PreventCleanup>False</PreventCleanup>
      <KeepAllVersionsNewerThanDays></KeepAllVersionsNewerThanDays>
      <KeepLatestVersionPerDayForDays></KeepLatestVersionPerDayForDays>
    </HistoryCleanup>
    <Folder>Shared</Folder>
    <Compositions>
      <Composition Key="76fed7ca-df43-4720-a52e-8659c9549fb1">introText</Composition>
      <Composition Key="02956852-8784-4059-b38f-a21bb7373a44">section</Composition>
    </Compositions>
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
