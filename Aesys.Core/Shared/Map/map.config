      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Paste the full Google Maps "Embed a map" <iframe> HTML. When set, the block is a 50/50 row with the map beside the text; when empty, the text spans full width.]]></Description>
