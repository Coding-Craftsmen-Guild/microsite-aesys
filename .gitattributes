# Normalize line endings: store LF in the repo, check out LF in working tree.
* text=auto eol=lf

# Scripts that run inside containers / Unix shells must stay LF.
*.sh text eol=lf

# Windows-only tooling expects CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
