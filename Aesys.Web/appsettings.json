{
  "$schema": "appsettings-schema.json",
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "d8e611af-2360-4cb3-b513-b2bea71748d6"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing",
        "ModelsNamespace": "Aesys.Core.Models",
        "FlagOutOfDateModels": false,
        "ModelsDirectory": "../Aesys.Core/Generated",
        "AcceptUnsafeModelsDirectory": true,
        "DebugLevel": 0
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Imaging": {
        "HMACSecretKey": "lq80VAUN/g0X0\u002BGNw\u002BLZp52jsrCXI/tK8vi5diWcwUilbOefNcWgtPzrC2hJyarn3Cmqv6eOMk4Nc9PHckDJ8w=="
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportAtStartup": "None",
      "ExportAtStartup": "None",
      "ExportOnSave": "All",
      "FailOnMissingParent": false
    },
    "Sets": {
      "Default": {
        "HandlerDefaults": {
          "UseFlatStructure": true,
          "GuidNames": false
        },
        "DisabledHandlers": [
          "TemplateHandler"
        ]
      }
    }
  }
}