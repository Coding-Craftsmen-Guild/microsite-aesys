      <Value Culture="en-US"><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "bb836be0-3ebb-452a-99d9-669b28331efc",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Products"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Cabinet <em>solutions</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">For energy providers and large systems</span></p>"
          }
        },
        {
          "alias": "backgroundColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "Navy"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "21de5165-63bb-4c29-a83e-34d9ab9af598",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-379 <em>High performance</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">Developed </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">for demanding industrial applications</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">With a capacity of 379.4 kWh and a C-rate of up to 1C, this system features </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">high power density and reliable operation in dynamic conditions</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">It is particularly suitable for applications requiring fast charge and discharge cycles, with </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">a service life of over 9,000 cycles.</span></strong></p><ul><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">Capacity 379.4 kWh</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">C-rate ≤ 1C</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">CATL battery cells 285 Ah / 3.2 V</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">Liquid cooling</span></strong></p></li></ul><p><a data-router-slot=\"disabled\" data-anchor=\"#\" href=\"#\" title=\"Skini specifikacije\" type=\"external\">Download specifications</a></p>"
          }
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "40c7a77a-9d10-4fdd-9a96-281c7e9da475",
              "mediaKey": "4dafda00-39bf-4dad-8246-40f7e64e3d17",
              "mediaTypeAlias": "",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "f01abc24-7bc0-40c6-b22a-3bbd7d4ef1fd",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-407 <em>Longevity</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">Developed for </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">long-term and stable energy solutions</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">With a capacity of 407.3 kWh and an optimized C-rate of ≤ 0.5C, this system provides </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">a balance between performance and longevity</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">It is designed for applications requiring high energy </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">density and an extended service life, with over 10,000 cycle</span></strong><span style=\"white-space: pre-wrap;\">s.</span><br></p><ul><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">Capacity 407.3 kWh</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">C-rate ≤ 0.5C</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">CATL battery cells 306 Ah / 3.2 V</span></strong></p></li><li><p><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">Liquid cooling</span></strong></p></li></ul><p><a data-router-slot=\"disabled\" data-anchor=\"#\" href=\"#\" title=\"Skini specifikacije\" type=\"external\">Download specifications</a></p>"
          }
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "f42397f2-742a-42b3-b5d8-8c7e1cadf895",
              "mediaKey": "4dafda00-39bf-4dad-8246-40f7e64e3d17",
              "mediaTypeAlias": "",
              "crops": [],
