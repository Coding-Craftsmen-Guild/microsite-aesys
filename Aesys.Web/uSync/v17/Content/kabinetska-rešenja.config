            "Navy"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "21de5165-63bb-4c29-a83e-34d9ab9af598",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-379 \u003Cem\u003EVisoke performanse\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ERazvijen \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Eza zahtevne industrijske primene\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ESa kapacitetom od 379,4 kWh i C-rate-om do 1C, ovaj sistem se odlikuje \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Evisokom gustinom snage i pouzdanim radom u dinami\u010Dnim uslovima\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EPosebno je pogodan za aplikacije koje zahtevaju brze cikluse punjenja i pra\u017Enjenja, uz \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003E\u017Eivotni vek od preko 9.000 ciklusa.\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EKapacitet 379,4 kWh\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EC-rate \u2264 1C\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003E\u0106elije baterije CATL 285 Ah / 3.2 V\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003ETe\u010Dno hla\u0111enje (liquid cooling)\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Ca data-router-slot=\u0022disabled\u0022 data-anchor=\u0022#\u0022 href=\u0022#\u0022 title=\u0022Skini specifikacije\u0022 type=\u0022external\u0022\u003ESkini specifikacije\u003C/a\u003E\u003C/p\u003E"
          }
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "40c7a77a-9d10-4fdd-9a96-281c7e9da475",
              "mediaKey": "4dafda00-39bf-4dad-8246-40f7e64e3d17",
              "mediaTypeAlias": "",
              "crops": [],
