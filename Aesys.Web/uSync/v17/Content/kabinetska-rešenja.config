            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EZa energetske provajdere i velike sisteme\u003C/span\u003E\u003C/p\u003E"
          }
        },
        {
          "alias": "backgroundColor",
          "culture": null,
