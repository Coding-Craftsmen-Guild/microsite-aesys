            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "f01abc24-7bc0-40c6-b22a-3bbd7d4ef1fd",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-407 \u003Cem\u003EDugotrajnost\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ERazvijen za \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Edugoro\u010Dna i stabilna energetska re\u0161enja\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ESa kapacitetom od 407,3 kWh i optimizovanim C-rate-om \u2264 0,5C, ovaj sistem pru\u017Ea \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Ebalans izme\u0111u performansi i dugove\u010Dnosti\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EDizajniran je za primene koje zahtevaju visoku energetsku \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Egustinu i produ\u017Een radni vek, sa preko 10.000 ciklus\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003Ea.\u003C/span\u003E\u003Cbr\u003E\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EKapacitet 407,3 kWh\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EC-rate \u2264 0,5C\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003E\u0106elije baterije CATL 306 Ah / 3.2 V\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003ETe\u010Dno hla\u0111enje (liquid cooling)\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Ca data-router-slot=\u0022disabled\u0022 data-anchor=\u0022#\u0022 href=\u0022#\u0022 title=\u0022Skini specifikacije\u0022 type=\u0022external\u0022\u003ESkini specifikacije\u003C/a\u003E\u003C/p\u003E"
          }
        },
