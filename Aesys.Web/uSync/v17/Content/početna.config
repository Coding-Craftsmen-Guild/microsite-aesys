      "contentTypeKey": "bfc7ae19-ff25-49a3-9dcb-f402e80f177b",
      "key": "0be03732-12c8-4046-9e50-49cc4c0c24b8",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Na\u0161 fokus"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Kompletno re\u0161enje\u2028od projektovanja do \u003Cem\u003Emonetizacije energije\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003EOd ideje do profita. Objedinjujemo projektovanje, prodaju \u003Cstrong\u003EBESS re\u0161enja\u003C/strong\u003E, instalaciju, operacije i odr\u017Eavanje, pravnu i finansijsku podr\u0161ku, kao i integraciju u virtualne elektrane. Na jednom mestu dobijate kompletnu ekspertizu potrebnu da energetski projekat bude tehni\u010Dki pouzdan, regulatorno uskla\u0111en i \u003Cstrong\u003Emaksimalno isplativ\u003C/strong\u003E.\u003C/p\u003E"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "Na\u0161a re\u0161enja",
              "target": null,
              "unique": null,
              "type": null,
              "udi": null,
              "url": "#",
              "queryString": null,
              "culture": null
            }
          ]
        },
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Prodaja BESS re\u0161enja\nInstalacija i pu\u0161tanje u rad\nOperacije i odr\u017Eavanje (O\u0026M)\nPravno-bankarski konsalting\nEnergetsko pravo\nVPP - Virtuelna elektrana"
        },
        {
          "alias": "overlay",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "d7523ab5-b6eb-4bd3-bca1-f9f59456cf08",
              "mediaKey": "ff434fe5-ff30-41ba-94c2-c8ea47c6ee06",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "0898df7b-a895-4363-8565-d247fa7db80d",
      "key": "11bfe3af-2fb5-4b9f-94a0-160ab12d4e9b",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Za\u0161to BESS"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Za\u0161to \u003Cem\u003Einvestirati\u003C/em\u003E u skladi\u0161tenje energije?"
        },
        {
          "alias": "perRow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "3"
          ]
        },
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "a0f35c87-2321-44e7-8218-7ff62b6c3d55",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Direktno smanjenje  tro\u0161kova (20\u201340%)"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Punjenje baterije u periodima niske cene i kori\u0161\u0107enje u vr\u0161nim satima.\u2028\n\nSvaki preme\u0161teni MWh generi\u0161e direktnu u\u0161tedu."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "1"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "68fa69e7-5985-4f9e-8794-6f8e92da0734",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Maksimizacija prinosa  solarne elektrane"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Porast self-consumption-a sa 30\u201340% na \u2028do 95%. \n\nEnergija se koristi kada ima najve\u0107u vrednost."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "2"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "b6ed75d4-8931-4b5d-adef-c4f9aceb5cd6",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Smanjenje tro\u0161kova vr\u0161ne snage (peak shaving)"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Trajno smanjenje priklju\u010Dne snage i fiksnih tro\u0161kova prema operatoru mre\u017Ee."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "3"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "4484659d-2108-4696-9a0c-7c921f8b008f",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Sigurnost napajanja \u2028bez diesel agregata"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Za\u0161tita kriti\u010Dnih procesa bez goriva, bez emisija i bez operativnih tro\u0161kova."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "4"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "ca38804f-4b29-48c1-bc2b-06fda4acea5e",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Novi izvor prihoda \u2028\u2014 balansno tr\u017Ei\u0161te"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Mogu\u0107nost dodatnih prihoda kroz sistemske usluge (frekvencija, rezerva, stabilizacija mre\u017Ee)."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "5"
                  }
                ]
              }
            ],
            "settingsData": [],
            "expose": [
              {
                "contentKey": "a0f35c87-2321-44e7-8218-7ff62b6c3d55",
