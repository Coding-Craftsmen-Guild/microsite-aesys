    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "9a026c03-2669-4790-8475-b97c7d91242e",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Free analysis"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "<em>Take control</em> of your energy costs!"
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">We offer a free analysis of your consumption and an assessment of the cost-effectiveness of a BESS system. Analysis delivery time: </span><strong><span style=\"white-space: pre-wrap;\">5 business days</span></strong></p>"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "Learn more",
              "target": null,
              "unique": null,
              "type": null,
              "udi": null,
              "url": "#",
              "queryString": null,
              "culture": null
            }
          ]
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "fdae6f13-5464-4c05-905e-e8d7ce8a65f0",
              "mediaKey": "9f2d0423-2033-4491-912c-89f9db36f82b",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "bfc7ae19-ff25-49a3-9dcb-f402e80f177b",
      "key": "0be03732-12c8-4046-9e50-49cc4c0c24b8",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Our focus"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A complete solution from design to <em>energy monetization</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p>From idea to profit. We bring together design, sales of <strong>BESS solutions</strong>, installation, operations and maintenance, legal and financial support, as well as integration into virtual power plants. In one place you get the complete expertise needed to make an energy project technically reliable, regulatory compliant and <strong>maximally cost-effective</strong>.</p>"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "Our solutions",
              "target": null,
              "unique": null,
              "type": null,
              "udi": null,
              "url": "#",
              "queryString": null,
              "culture": null
            }
          ]
        },
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Sales of BESS solutions\nInstallation and commissioning\nOperations and maintenance (O&M)\nLegal and banking consulting\nEnergy law\nVPP - Virtual power plant"
        },
        {
          "alias": "overlay",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "d7523ab5-b6eb-4bd3-bca1-f9f59456cf08",
              "mediaKey": "ff434fe5-ff30-41ba-94c2-c8ea47c6ee06",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "0898df7b-a895-4363-8565-d247fa7db80d",
      "key": "11bfe3af-2fb5-4b9f-94a0-160ab12d4e9b",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Why BESS"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Why <em>invest</em> in energy storage?"
        },
        {
          "alias": "perRow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "3"
          ]
        },
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "a0f35c87-2321-44e7-8218-7ff62b6c3d55",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Direct cost reduction (20–40%)"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Charging the battery during low-price periods and using it during peak hours. \n\nEvery shifted MWh generates direct savings."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "1"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "68fa69e7-5985-4f9e-8794-6f8e92da0734",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Maximizing solar power plant yield"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Raising self-consumption from 30–40% to as much as 95%. \n\nEnergy is used when it has the highest value."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "2"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "b6ed75d4-8931-4b5d-adef-c4f9aceb5cd6",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Reducing peak power costs (peak shaving)"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Permanent reduction of connected load and fixed costs payable to the grid operator."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "3"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "4484659d-2108-4696-9a0c-7c921f8b008f",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Power supply security without a diesel generator"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Protection of critical processes with no fuel, no emissions and no operating costs."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "4"
                  }
                ]
              },
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "ca38804f-4b29-48c1-bc2b-06fda4acea5e",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "A new revenue source — the balancing market"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "The potential for additional revenue through ancillary services (frequency, reserve, grid stabilization)."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "5"
                  }
                ]
              }
            ],
            "settingsData": [],
            "expose": [
              {
                "contentKey": "a0f35c87-2321-44e7-8218-7ff62b6c3d55",
                "culture": null,
                "segment": null
