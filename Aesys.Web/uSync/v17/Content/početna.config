        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Systems"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "<em>Features</em> of our solutions"
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<ul><li><p>Modular and scalable systems</p></li><li><p>Integration with existing infrastructure</p></li><li><p>Advanced management systems (EMS)</p></li><li><p>High standards of safety and reliability</p></li></ul><p></p>"
          }
        },
        {
