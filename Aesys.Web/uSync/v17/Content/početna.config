      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Next step"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Talk to our <em>team</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><strong data-start=\"516\" data-end=\"548\">Send an inquiry through the form</strong><br>Provide basic information about your project, and our team will contact you with a proposed solution.</p><p data-start=\"646\" data-end=\"770\" data-is-last-node=\"\" data-is-only-node=\"\"><strong data-start=\"646\" data-end=\"675\">A response within 24 hours</strong><br>Once we receive your inquiry, you will get feedback and the next steps for carrying out the project.</p>"
          }
        },
        {
          "alias": "formTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Send a message"
        },
        {
          "alias": "formSubtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Our team will pick up your inquiry and respond within 24h."
        },
        {
          "alias": "recipients",
          "culture": null,
          "editorAlias": null,
