          "value": [
            "Navy"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "11100b16-7930-4503-a579-a89dac81f1b2",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-3790 \u003Cem\u003EVisoke performanse\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ENamenjen \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Evelikim industrijskim i infrastrukturnim primenama\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ESa kapacitetom u rasponu od 1805 kWh do 3790 kWh i C-rate-om do 1C, sistem je pogodan za primene koje \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Ezahtevaju brzu reakciju i \u010Deste cikluse punjenja i pra\u017Enjenja\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EOdlikuje se visokom gustinom snage, \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Eskalabilno\u0161\u0107u i \u017Eivotnim vekom od preko 9.000 ciklusa\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EKapacitet 1805 \u2013 3790 kWh\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EC-rate \u2264 1C\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003E\u0106elije baterije CATL 285 Ah / 3.2 V\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003ETe\u010Dno hla\u0111enje (liquid cooling)\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Ca data-router-slot=\u0022disabled\u0022 href=\u0022#\u0022 title=\u0022Skini specifikacije\u0022 data-anchor=\u0022#\u0022 type=\u0022external\u0022\u003ESkini specifikacije\u003C/a\u003E\u003C/p\u003E"
          }
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "f0755a95-4062-48d6-9df4-1de4d7c15f81",
              "mediaKey": "c13c8331-7317-4529-844d-15d189f41741",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "aa00a66b-9998-4d3e-98f8-00c9fe4263c9",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Luminary-4070 \u003Cem\u003EDugotrajnost\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ENamenjen za \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Edugoro\u010Dna energetska re\u0161enja u velikim projektima.\u003C/span\u003E\u003C/strong\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ESa kapacitetom od 2035 kWh do 4070 kWh i optimizovanim C-rate-om \u2264 0,5C, \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Epru\u017Ea balans izme\u0111u kapaciteta i dugove\u010Dnosti.\u003C/span\u003E\u003C/strong\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EDizajniran je za primene koje zahtevaju \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Evisoku energetsku gustinu i produ\u017Een radni vek, uz preko 10.000 ciklusa.\u003C/span\u003E\u003C/strong\u003E\u003Cbr\u003E\u003Cbr\u003E\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EKapacitet 2035 to 4070 kWh\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EC-rate \u2264 0,5C\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003E\u0106elije baterije CATL 306 Ah / 3.2 V\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003ETe\u010Dno hla\u0111enje (liquid cooling)\u003C/span\u003E\u003C/strong\u003E\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003Ca data-router-slot=\u0022disabled\u0022 data-anchor=\u0022#\u0022 href=\u0022#\u0022 title=\u0022Skini specifikacije\u0022 type=\u0022external\u0022\u003ESkini specifikacije\u003C/a\u003E\u003C/p\u003E"
          }
        },
