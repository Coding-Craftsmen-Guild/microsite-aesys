                "key": "88d3c61b-5daa-4324-96de-66248e8af3fd",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Integration"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "We ensure reliable integration of BESS systems with existing power infrastructure, EMS platforms and renewable energy sources. Our focus is stable system operation, maximum efficiency and simple energy management."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "2"
                  },
                  {
                    "alias": "icon",
                    "culture": null,
                    "editorAlias": null,
