      <Value Culture="en-US"><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "85c702ef-ffaa-4039-8f2b-54b8b3762168",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "MISSION AND VISION"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The future we <em>are building</em>."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">Applied Energy Systems doo is building the infrastructure of </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">the future energy of the Balkans</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">Every implemented system represents a step toward a </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">more decentralized, more resilient and more efficient energy grid</span></strong><span style=\"white-space: pre-wrap;\">.</span><br><br><span style=\"white-space: pre-wrap;\">We help companies and energy systems take control of their energy consumption, stability and costs through modern </span><strong><span style=\"font-weight: bold; white-space: pre-wrap;\">BESS solutions</span></strong><span style=\"white-space: pre-wrap;\">.</span></p>"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "View services",
              "target": null,
              "unique": null,
              "type": null,
              "udi": null,
              "url": "#",
              "queryString": null,
              "culture": null
            }
          ]
        },
