      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How we deliver projects"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Areas of <em>expertise</em>."
        },
        {
          "alias": "items",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "8465a727-27c5-4590-8af1-11e61f532527",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Design"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "We analyze consumption, loads and energy patterns to design a BESS system tailored to the user's real needs. We shape every solution according to capacity, energy usage and the project's long-term goals."
                  },
                  {
                    "alias": "number",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "1"
                  },
                  {
                    "alias": "icon",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "key": "f8737d17-b6d4-42d4-8628-0e1615d389e0",
