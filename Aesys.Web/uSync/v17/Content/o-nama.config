    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "82505aa4-4538-46f4-ae0a-970980e937dd",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Stvarna a ne budu\u0107a potreba"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "\u003Cem\u003EEnergetski sektor\u003C/em\u003E se menja br\u017Ee nego ikad!"
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ERast cena energije, sve ve\u0107a nestabilnost mre\u017Ee i ubrzana integracija obnovljivih izvora menjaju na\u010Din na koji industrija koristi energiju.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EDanas se energija ne posmatra samo kroz proizvodnju, ve\u0107 kroz fleksibilnost i upravljanje potro\u0161njom.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EU tom kontekstu, BESS sistemi vi\u0161e nisu \u201Cbudu\u0107a tehnologija\u201D \u2014 ve\u0107 klju\u010Dni deo savremene energetske infrastrukture.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EOmogu\u0107avaju:\u003C/span\u003E\u003Cbr\u003E\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003Esmanjenje vr\u0161nih optere\u0107enja (peak shaving)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Estabilizaciju mre\u017Ee\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Eefikasnije kori\u0161\u0107enje obnovljivih izvora\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003Eve\u0107u kontrolu energetskih tro\u0161kova\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003E\u003C/p\u003E"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "fdae6f13-5464-4c05-905e-e8d7ce8a65f0",
