          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EApplied Energy Systems doo gradi infrastrukturu \u2028\u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Ebudu\u0107e energetike Balkana\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ESvaki implementirani sistem predstavlja korak ka \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003Edecentralizovanijoj, otpornijoj i efikasnijoj energetskoj mre\u017Ei\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EPoma\u017Eemo kompanijama i energetskim sistemima da preuzmu kontrolu nad potro\u0161njom, stabilno\u0161\u0107u i tro\u0161kovima energije kroz savremena \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022font-weight: bold; white-space: pre-wrap;\u0022\u003EBESS re\u0161enja\u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003E.\u003C/span\u003E\u003C/p\u003E"
