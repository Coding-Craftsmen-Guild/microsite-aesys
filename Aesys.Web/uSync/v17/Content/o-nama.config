                "contentTypeKey": "1bcc0f78-4a00-4c7d-979a-2efc66cc18b2",
                "key": "50ef00a0-ebe2-4cef-8519-3c7157d43ee3",
                "values": [
                  {
                    "alias": "title",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "Maintenance"
                  },
                  {
                    "alias": "text",
                    "culture": null,
                    "editorAlias": null,
                    "segment": null,
                    "value": "We provide continuous system monitoring, technical support and performance optimization throughout the project's entire lifecycle. Through preventive maintenance and rapid response, we ensure the safety, stability and long-term reliability of the system."
