        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Free analysis"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "<em>Take control</em> of your energy costs!"
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">We offer a free analysis of your consumption and an assessment of a BESS system's cost-effectiveness. Analysis turnaround time: </span><strong><span style=\"white-space: pre-wrap;\">5 business days</span></strong></p>"
