    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "82505aa4-4538-46f4-ae0a-970980e937dd",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A real need, not a future one"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "<em>The energy sector</em> is changing faster than ever!"
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "<p><span style=\"white-space: pre-wrap;\">Rising energy prices, growing grid instability and the accelerated integration of renewable sources are changing the way industry uses energy.</span><br><br><span style=\"white-space: pre-wrap;\">Today, energy is viewed not only through production, but through flexibility and consumption management.</span><br><br><span style=\"white-space: pre-wrap;\">In that context, BESS systems are no longer “future technology” — but a key part of modern energy infrastructure.</span><br><br><span style=\"white-space: pre-wrap;\">They enable:</span><br></p><ul><li><p>reducing peak loads (peak shaving)</p></li><li><p>grid stabilization</p></li><li><p>more efficient use of renewable sources</p></li><li><p>greater control of energy costs</p></li></ul><p></p>"
          }
        },
        {
          "alias": "button",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        },
        {
          "alias": "image",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "fdae6f13-5464-4c05-905e-e8d7ce8a65f0",
              "mediaKey": "9f2d0423-2033-4491-912c-89f9db36f82b",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "357daa49-081a-4e58-841e-adf6514cba2f",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "“We design every system according to the user's real energy needs, existing infrastructure and the project's long-term goals.”"
        },
        {
          "alias": "background",
          "culture": null,
          "editorAlias": null,
          "segment": null,
