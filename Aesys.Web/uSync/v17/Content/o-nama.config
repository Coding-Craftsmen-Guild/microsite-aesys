              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "b0c51460-6d98-44e8-8b81-22c4d2839082",
      "key": "357daa49-081a-4e58-841e-adf6514cba2f",
      "values": [
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "\u201CSvaki sistem projektujemo prema stvarnim energetskim potrebama korisnika, postoje\u0107oj infrastrukturi i dugoro\u010Dnim ciljevima projekta.\u201D"
        },
        {
          "alias": "background",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "34eedb1f-970d-463e-b3df-cb27e7680ef4",
