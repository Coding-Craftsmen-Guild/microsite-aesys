            "markup": "<p><span style=\"white-space: pre-wrap;\">✓       Estimated annual savings </span><br><span style=\"white-space: pre-wrap;\">✓       Recommended BESS system configuration (cabinet or container)</span><br><span style=\"white-space: pre-wrap;\">✓       Estimated payback period</span><br><span style=\"white-space: pre-wrap;\">✓       Overview of possible revenue sources (peak shaving, arbitrage, balancing market)</span><br><span style=\"white-space: pre-wrap;\">✓      Next steps and indicative project budget</span><br><br><a data-router-slot=\"disabled\" href=\"#\" title=\"#\" data-anchor=\"#\" type=\"external\"><span style=\"white-space: pre-wrap;\">Download questionnaire</span></a></p><p><span style=\"white-space: pre-wrap;\">Applied Energy Systems doo</span><br><span style=\"white-space: pre-wrap;\">Bulevar Mihajla Pupina 20/I Novi Sad, Serbia</span><br><br><a data-router-slot=\"disabled\" href=\"mailto:info@aesys.rs\" type=\"external\"><span style=\"white-space: pre-wrap;\">info@aesys.rs</span></a><span style=\"white-space: pre-wrap;\"> </span><br><span style=\"white-space: pre-wrap;\">Working hours: Mon–Fri, 09:00–17:00</span></p>"
