      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "USLUGE I PODR\u0160KA"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Podr\u0161ka kroz ceo \u017Eivotni ciklus va\u0161eg sistema."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ERazumemo da su kvalitetan servis i stru\u010Dna podr\u0161ka klju\u010Dni za dugoro\u010Dan uspeh sistema za skladi\u0161tenje energije.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003ENa\u0161 tim pru\u017Ea sveobuhvatnu tehni\u010Dku ekspertizu kako bi obezbedio optimalne performanse, pouzdan rad i dug vek trajanja va\u0161ih BESS sistema.\u003C/span\u003E\u003Cbr\u003E\u003Cbr\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EOd planiranja i implementacije do kontinuiranog monitoringa i odr\u017Eavanja, pru\u017Eamo podr\u0161ku prilago\u0111enu specifi\u010Dnim zahtevima svakog projekta, sa ciljem da maksimalno pove\u0107amo vrednost va\u0161e investicije.\u003C/span\u003E\u003C/p\u003E"
          }
        },
