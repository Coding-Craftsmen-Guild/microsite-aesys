              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        }
      ]
    },
    {
      "contentTypeKey": "c0a7f3e1-2b4d-4f6a-8c1e-9d3b5a7e1f20",
      "key": "682517d6-6f71-48b3-8e13-fd6ba7426a1c",
      "values": [
        {
          "alias": "eyebrow",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Slede\u0107i korak"
        },
        {
          "alias": "title",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Razgovarajte sa  na\u0161im \u003Cem\u003Etimom\u003C/em\u003E."
        },
        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cstrong data-start=\u0022516\u0022 data-end=\u0022548\u0022\u003EPo\u0161aljite upit putem obrasca\u003C/strong\u003E\u003Cbr\u003EDostavite osnovne informacije o projektu, a na\u0161 tim \u0107e vas kontaktirati sa predlogom re\u0161enja.\u003C/p\u003E\u003Cp data-start=\u0022646\u0022 data-end=\u0022770\u0022 data-is-last-node=\u0022\u0022 data-is-only-node=\u0022\u0022\u003E\u003Cstrong data-start=\u0022646\u0022 data-end=\u0022675\u0022\u003EOdgovor u roku od 24 \u010Dasa\u003C/strong\u003E\u003Cbr\u003ENakon prijema upita, dobi\u0107ete povratnu informaciju i naredne korake za realizaciju projekta.\u003C/p\u003E"
          }
        },
        {
          "alias": "formTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Po\u0161aljite poruku"
        },
        {
          "alias": "formSubtitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Na\u0161 tim \u0107e preuzeti Va\u0161 upit i odgovoriti u roku od 24h."
        },
        {
          "alias": "recipients",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "maksimbogunovic@gmail.com"
        },
