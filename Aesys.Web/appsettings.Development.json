{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Hosting": {
        "Debug": true
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@local",
        "UnattendedUserPassword": "LocalDev1234!"
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeAuto"
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportAtStartup": "All",
      "ExportOnSave": "Settings"
    },
    "Sets": {
      "Default": {
        "DisabledHandlers": [
          "ContentHandler",
          "MediaHandler",
          "TemplateHandler"
        ],
        "Handlers": {
          "ContentTypeHandler": { "Actions": ["Import"] },
          "DictionaryHandler":  { "Actions": ["Import"] }
        }
      }
    }
  }
}
