@using Aesys.Core.Components.UI.Button
@model Aesys.Core.Compositions.LanguageSelector.LanguageSelectorViewModel

@{
    // Native <details> disclosure: the <summary> is the current-language pill, the
    // panel lists every language (current one marked, others link to that culture).
    // Works without JS — the tiny language-selector.ts only adds outside-click /
    // Escape close. `Placement` flips the panel above the pill in the footer.
    var current = Model.Languages.FirstOrDefault(l => l.IsCurrent) ?? Model.Languages.FirstOrDefault();
    var up = string.Equals(Model.Placement, "up", StringComparison.OrdinalIgnoreCase);
    var alignStart = string.Equals(Model.Align, "start", StringComparison.OrdinalIgnoreCase);
}

@if (current is not null && Model.Languages.Count > 1)
{
    <details class="relative inline-block" data-component="language-selector">
        <summary class="@Html.Cn(ButtonVariants.Base, ButtonVariants.Variant("lang"), ButtonVariants.Size("sm"), "cursor-pointer select-none")"
                 aria-label="@Html.Tr("Header.SelectLanguage")">
            <span>@current.Short</span>
            <svg class="lang-chevron h-3 w-3 transition-transform duration-200" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1.5 6 6.5 11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </summary>

        <ul class="@Html.Cn("absolute z-50 min-w-[8rem] overflow-hidden rounded-md border border-white/20 bg-aesys-800 py-1 shadow-lg", alignStart ? "left-0" : "right-0", up ? "bottom-full mb-2" : "top-full mt-2")">
            @foreach (var lang in Model.Languages)
            {
                <li>
                    @if (lang.IsCurrent)
                    {
                        <span class="flex items-center justify-between gap-4 px-4 py-2 text-sm font-bold text-white" aria-current="true">
                            <span>@lang.Short</span>
                            <svg class="h-3.5 w-3.5 shrink-0 text-accent-500" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                                <path d="M2 7.5 5.5 11 12 3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    }
                    else
                    {
                        <a href="@lang.Url" class="flex items-center justify-between gap-4 px-4 py-2 text-sm font-bold text-white/70 transition hover:bg-white/10 hover:text-white">
                            <span>@lang.Short</span>
                        </a>
                    }
                </li>
            }
        </ul>
    </details>
}
