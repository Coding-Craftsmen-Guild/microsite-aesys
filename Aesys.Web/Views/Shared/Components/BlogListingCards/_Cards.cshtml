@model Aesys.Core.Components.BlogLandingPage.BlogListingCards.BlogCardsViewModel

@foreach (var card in Model.Items)
{
    <li class="flex grow basis-[20rem] sm:max-w-[calc(50%-0.75rem)] lg:max-w-[calc(33.333%-1rem)]">
        <article class="flex w-full flex-col overflow-hidden rounded-md border border-aesys-100 bg-white text-aesys-800">
            @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
            {
                <img src="@card.ImageUrl" alt="" class="aspect-16/10 w-full object-cover" />
            }

            <div class="flex flex-1 flex-col p-5">
                @if (card.Date != default(DateTime))
                {
                    <time datetime="@card.Date.ToString("yyyy-MM-dd")" class="text-footnote text-aesys-800/60">@card.Date.ToString("MMMM d, yyyy")</time>
                }

                @if (!string.IsNullOrWhiteSpace(card.Title))
                {
                    <h3 class="mt-2 text-h4 font-bold">@card.Title</h3>
                }

                @if (!string.IsNullOrWhiteSpace(card.Excerpt))
                {
                    <p class="mt-3 line-clamp-3 text-base text-aesys-800/80">@card.Excerpt</p>
                }

                <a href="@card.Url" class="mt-auto inline-flex items-center gap-2 self-end pt-5 font-medium text-accent-500">
                    <span class="underline">Read more</span>
                    <span aria-hidden="true">&#10148;</span>
                </a>
            </div>
        </article>
    </li>
}

@* Server-authoritative Load-More button. Rendered into the slot on every
   response (initial + each fetch); absent on the final page so the client simply
   ends up with an empty slot. The JS reads data-* for the next request — it
   never computes the cursor itself. *@
@if (Model.HasMore)
{
    <li data-load-more-slot class="flex w-full justify-center">
        <button type="button"
                class="inline-flex h-control items-center rounded-full bg-accent-500 px-8 text-base font-medium text-aesys-800 transition hover:bg-accent-400 disabled:opacity-60"
                data-load-more
                data-url="@Url.Action("Cards", "BlogListing")"
                data-page-id="@Model.PageId"
                data-skip="@Model.NextSkip"
                data-take="@Model.PageSize">
            Load more
        </button>
    </li>
}
