@model Aesys.Core.Compositions.Header.HeaderViewModel
@using Aesys.Core.Compositions.Header

<nav class="bg-white border-b border-gray-200" data-component="header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">

            <div class="shrink-0">
                @if (Model.Logo is not null)
                {
                    <a href="/" aria-label="Home">
                        <img src="@Model.Logo.Url()" alt="" class="@HeaderVariants.Logo" />
                    </a>
                }
                else
                {
                    <a href="/" class="text-xl font-bold">MyApp</a>
                }
            </div>

            <div class="hidden md:flex items-center gap-6">
                <a href="#" class="text-gray-700 hover:text-black">Home</a>
                <a href="#" class="text-gray-700 hover:text-black">About</a>
                <a href="#" class="text-gray-700 hover:text-black">Services</a>
                <a href="#" class="text-gray-700 hover:text-black">Contact</a>

                <button class="rounded-md bg-black px-4 py-2 text-white hover:opacity-90">
                    Login
                </button>
            </div>

            <button type="button" class="md:hidden p-2" data-header-toggle aria-label="Toggle menu">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

        </div>
    </div>
</nav>
