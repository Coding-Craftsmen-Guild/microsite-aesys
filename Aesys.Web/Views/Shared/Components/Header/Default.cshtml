@model Aesys.Core.Compositions.Header.HeaderViewModel
@using Aesys.Core.Compositions.Header

<nav class="@HeaderVariants.Base" data-component="header">
  <div class="wrapper">
  <div class="relative flex h-20 items-center justify-between gap-4 border-b border-white">

    <div class="shrink-0">
        <a href="/" aria-label="@(string.IsNullOrWhiteSpace(Model.SiteName) ? Html.Tr("Common.Home") : Model.SiteName)">
            @if (Model.Logo is not null)
            {
                <img src="@Model.Logo.Url()" alt="@Model.SiteName" class="max-h-10 w-auto" />
            }
            else
            {
                <span class="text-xl font-black text-white">@Model.SiteName</span>
            }
        </a>
    </div>

    <div class="hidden items-center gap-8 md:flex">
        @foreach (var item in Model.Items)
        {
            <partial name="Components/Header/_DesktopNavItem" model="item" />
        }
    </div>

    <div class="hidden items-center gap-3 md:flex">
        @await Component.InvokeAsync("LanguageSelector", new { languages = Model.Languages })

        @if (Model.Button is not null)
        {
            @await Component.InvokeAsync("Button", new
            {
                label = Model.Button.Name,
                href = Model.Button.Url,
                target = Model.Button.Target,
                variant = "primary",
                size = "sm",
                arrow = true,
            })
        }
    </div>

    <button type="button" class="inline-flex items-center justify-center rounded-md p-2 text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 md:hidden" data-header-toggle aria-label="@Html.Tr("Header.ToggleMenu")">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

  </div>
  </div>

    <div class="header-mobile-menu absolute inset-x-0 top-16 z-50 flex flex-col gap-4 border-b border-divider/20 bg-aesys-800 px-6 py-6 md:hidden">
        @foreach (var item in Model.Items)
        {
            <partial name="Components/Header/_MobileNavItem" model="item" />
        }

        <div class="flex">
            @await Component.InvokeAsync("LanguageSelector", new { languages = Model.Languages, align = "start" })
        </div>

        @if (Model.Button is not null)
        {
            @await Component.InvokeAsync("Button", new
            {
                label = Model.Button.Name,
                href = Model.Button.Url,
                target = Model.Button.Target,
                variant = "primary",
                size = "sm",
                arrow = true,
            })
        }
    </div>
</nav>
