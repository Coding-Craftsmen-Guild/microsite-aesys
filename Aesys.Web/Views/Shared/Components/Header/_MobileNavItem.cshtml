@using Aesys.Core.Compositions.Header
@using Aesys.Core.Services
@model NavItem

@if (Model.Children.Count > 0)
{
    <div data-nav-accordion>
        <div class="flex items-center justify-between">
            <a href="@Model.Url" class="@HeaderVariants.NavLink(Model.IsActive)">@Model.Label</a>
            <button type="button" class="inline-flex items-center justify-center p-2 text-white" data-nav-accordion-toggle aria-label="@Html.Tr("Header.ToggleSubmenu")" aria-expanded="false">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
        </div>
        <div class="mt-2 hidden flex-col gap-2 pl-4" data-nav-accordion-panel>
            @foreach (var child in Model.Children)
            {
                <a href="@child.Url" class="@HeaderVariants.NavLink(child.IsActive)">@child.Label</a>
            }
        </div>
    </div>
}
else
{
    <a href="@Model.Url" class="@HeaderVariants.NavLink(Model.IsActive)">@Model.Label</a>
}
