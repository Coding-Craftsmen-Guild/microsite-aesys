@model Aesys.Core.Shared.ContactForm.ContactSuccessViewModel

@{
    var theme = string.IsNullOrWhiteSpace(Model.Theme) ? "light" : Model.Theme;
    var iconBg = theme == "dark" ? "bg-white text-aesys-800" : "bg-accent-500 text-aesys-800";
    var sub = theme == "dark" ? "text-white/70" : "text-aesys-800/70";
}

<div class="flex flex-col items-center gap-4 py-6 text-center" data-contact-success role="status">
    <span class="@iconBg flex size-14 items-center justify-center rounded-full text-2xl font-bold leading-none" aria-hidden="true">&#10003;</span>
    <h3 class="text-h4 font-bold">@Html.T("ContactForm.SuccessTitle")</h3>
    <p class="@sub max-w-sm text-base">@Html.T("ContactForm.SuccessBody")</p>
</div>
