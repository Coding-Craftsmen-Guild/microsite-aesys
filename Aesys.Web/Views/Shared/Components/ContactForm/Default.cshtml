@model Aesys.Core.Shared.ContactForm.ContactFormViewModel
@using Aesys.Core.Shared.ContactForm
@using Aesys.Core.Components.UI.Section

@{
    var theme = SectionVariants.Theme(Model.BackgroundColor, Model.Background is not null);

    // Fresh, empty submission for the initial render. Recipients rides along as a
    // hidden field so the POST knows where to send (server-trusted: it's the
    // block's configured address, never visitor input).
    var submission = new ContactFormSubmission { Recipients = Model.Recipients, Theme = theme };
}

<section-block bg-image="@(Model.Background?.Url())" bg-color="@Model.BackgroundColor" data-component="contact-form">
    <div class="flex flex-col gap-12 md:flex-row md:flex-wrap md:items-start md:gap-25">
        <div class="w-full md:flex-1 md:basis-0 md:min-w-[20rem]">
            @await Component.InvokeAsync("IntroText", new { source = Model.Intro, theme })
        </div>

        <div class="w-full md:flex-1 md:basis-0 md:min-w-[20rem]">
            <div class="@Html.Cn(ContactFormVariants.Card, ContactFormVariants.CardFill(theme))">
                @if (!string.IsNullOrWhiteSpace(Model.FormTitle))
                {
                    <h3 class="text-h4 font-bold">@Model.FormTitle</h3>
                }

                @if (!string.IsNullOrWhiteSpace(Model.FormSubtitle))
                {
                    <p class="@(theme == "dark" ? "text-white/70" : "text-aesys-800/70") mt-2 text-base">@Model.FormSubtitle</p>
                }

                @* Stable swap target. contact-form.ts replaces the inner partial
                   with the server's response (re-rendered form on error, success
                   message on success), so this wrapper must persist across swaps. *@
                <div class="mt-6" data-contact-form data-theme="@theme">
                    <partial name="Components/ContactForm/_Form" model="submission" />
                </div>
            </div>
        </div>
    </div>
</section-block>
