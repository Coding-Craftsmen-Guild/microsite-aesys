@model Aesys.Core.Components.HomePage.HeroBanner.HeroBannerViewModel

<section-block bg-image="@(Model.Background?.Url())" data-component="hero-banner">
    <div class="flex flex-col gap-16 md:gap-26">
        <div class="flex max-w-2xl flex-col items-start gap-10">
            @await Component.InvokeAsync("Pill", new { label = Model.Eyebrow, theme = "dark" })

            @if (!string.IsNullOrWhiteSpace(Model.Title))
            {
                <h1 class="text-h1 tracking-tight [&_em]:not-italic [&_em]:text-accent-500">@Html.Raw(Model.Title)</h1>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Text))
            {
                <p class="max-w-2xl whitespace-pre-line text-lg">@Model.Text</p>
            }

            @if (Model.Features.Count > 0)
            {
                <div class="flex flex-col gap-2">
                    @foreach (var feature in Model.Features)
                    {
                        <div class="flex items-center gap-3 text-base ">
                            @if (feature.Icon is not null)
                            {
                                <img src="@feature.Icon.Url()" alt="" class="h-6 w-6 shrink-0 object-contain" />
                            }
                            <span>@feature.Text</span>
                        </div>
                    }
                </div>
            }

            @if (Model.Button is not null)
            {
                @await Component.InvokeAsync("Button", new
                {
                    label = Model.Button.Name,
                    href = Model.Button.Url,
                    target = Model.Button.Target,
                    variant = "primary",
                    size = "md",
                    arrow = false,
                })
            }

        </div>

        @if (Model.Stats.Count > 0 || !string.IsNullOrWhiteSpace(Model.Footnote))
        {
            <div>
                @if (Model.Stats.Count > 0)
                {
                    <div class="flex flex-col gap-8 sm:flex-row sm:gap-0 sm:divide-x sm:divide-white/40">
                        @foreach (var stat in Model.Stats)
                        {
                            <div class="flex text-center items-center flex-col sm:px-8 sm:first:pl-0 sm:items-start">
                                <span class="text-stat font-extrabold leading-none ">@stat.Value</span>
                                <span class="mt-2 max-w-48 text-base ">@stat.Label</span>
                            </div>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Footnote))
                {
                    <p class="mt-8 text-footnote text-white/80">@Model.Footnote</p>
                }
            </div>
        }
    </div>
</section-block>
